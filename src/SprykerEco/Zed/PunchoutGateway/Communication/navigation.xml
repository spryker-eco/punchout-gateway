            </edit>
            <view>
                <title>View Punchout Connection</title>
                <bundle>punchout-gateway</bundle>
                <controller>view</controller>
                <action>index</action>
                <visible>0</visible>
            </view>
            <credential-add-credential>
                <title>Add Credential</title>
                <bundle>punchout-gateway</bundle>
                <controller>credential</controller>
                <action>add-credential</action>
                <visible>0</visible>
            </credential-add-credential>
            <credential-edit-credential>
                <title>Edit Credential</title>
                <bundle>punchout-gateway</bundle>
                <controller>credential</controller>
                <action>edit-credential</action>
                <visible>0</visible>
            </credential-edit-credential>
