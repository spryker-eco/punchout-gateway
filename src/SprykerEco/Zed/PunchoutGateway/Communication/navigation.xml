<?xml version="1.0"?>
<config>
    <punchout-gateway>
        <label>Punchout Connections</label>
        <bundle>punchout-gateway</bundle>
        <controller>list</controller>
        <action>index</action>
        <visible>1</visible>
        <pages>
            <create>
                <title>Create Punchout Connection</title>
                <bundle>punchout-gateway</bundle>
                <controller>create</controller>
                <action>index</action>
                <visible>0</visible>
            </create>
            <edit>
                <title>Edit Punchout Connection</title>
                <bundle>punchout-gateway</bundle>
                <controller>edit</controller>
                <action>index</action>
